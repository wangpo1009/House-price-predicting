    {
      "cell_type": "code",
      "source": [
        "from sklearn.pipeline import Pipeline\n",
        "from sklearn.impute import SimpleImputer\n",
        "\n",
        "num_pipeline = Pipeline([\n",
        "    ('imputer', SimpleImputer(strategy='median')), # Điền null bằng trung vị trước\n",
        "    ('scaler', StandardScaler())                    # Rồi mới chuẩn hóa sau\n",
        "])\n",
        "\n",
        "cat_pipeline = Pipeline([\n",
        "    ('imputer', SimpleImputer(strategy='most_frequent')),  # Điền chỗ trống = giá trị misin\n",
        "    ('onehot', OneHotEncoder(handle_unknown='ignore')) # Encode\n",
        "])\n",
        "\n",
        "preprocessor = ColumnTransformer(\n",
        "    transformers=[\n",
        "        ('num', num_pipeline, num_cols),\n",
        "        ('cat', cat_pipeline, cat_cols) # Dùng pipeline thay vì gọi trực tiếp OneHotEncoder\n",
        "    ])\n",
        "\n",
        "data_processed = preprocessor.fit_transform(data)"
      ],
      "metadata": {
        "id": "hWVYaNmmSg5c"
      },
      "execution_count": 57,
      "outputs": []
