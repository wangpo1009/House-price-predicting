      "source": [
        "from sklearn.linear_model import LinearRegression\n",
        "\n",
        "# Gọi mô hình\n",
        "model = LinearRegression()\n",
        "\n",
        "# Luyện\n",
        "model.fit(data_processed, data['SalePrice'])\n",
        "\n",
        "# Đánh giá\n",
        "score = model.score(data_processed, data['SalePrice'])\n",
        "\n",
        "print(score)"
      ],
